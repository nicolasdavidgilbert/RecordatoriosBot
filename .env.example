# ============================================================
#  RecordatoriosBot — Configuración de ejemplo
#  Copiá este archivo como .env y completá los valores reales
# ============================================================

# Token del bot de Telegram (obtenelo con @BotFather)
TELEGRAM_BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Chat ID que recibirá los mensajes por defecto (si no se especifica uno por dispositivo)
# Podés conseguirlo hablándole a @userinfobot en Telegram
CHAT_ID_DEFAULT=1234567890

# -----------------------------------------------
#  DEVICES — Lista de dispositivos a vigilar
#  Formato: Nombre:IP:ChatId(opcional)
#
#  • Nombre  → Identificador (aparece en los logs)
#  • IP      → IP local del dispositivo en la red
#  • ChatId  → (opcional) Si se omite, usa CHAT_ID_DEFAULT
#
#  Separar múltiples dispositivos con coma.
# -----------------------------------------------
DEVICES=Nico:192.168.1.100:1234567890,Mama:192.168.1.101:9876543210,Papa:192.168.1.102
